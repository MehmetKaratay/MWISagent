# Local development configuration
# For deployment, these are set via Terraform / the deploy command.

# Vertex AI Configuration (default)
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=global

# Alternatively, for Gemini API via Google AI Studio,
# comment out the three lines above and uncomment:
GEMINI_API_KEY=api-key-key

# Google OAuth Client ID to validate the audience of incoming JWT tokens
GOOGLE_OAUTH_CLIENT_ID=your-oauth-client-id-here

# CORS ALLOW_ORIGINS
ALLOW_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Modes
MWIS_ENV=development
USE_LIVE_FORECAST=true
PROJECT_ID=project-id-here
HIDDEN_REFRESH_COMMAND=hidden-cmd-here
